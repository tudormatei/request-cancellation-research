POSTGRES_DB=thesisdb
POSTGRES_USER=thesisuser
POSTGRES_PASSWORD=thesispass
POSTGRES_PORT=5432

ASPNET_PORT=8081
SPRING_PORT=8082
SPRING_WEBFLUX_PORT=8083
GO_PORT=8084

ASPNET_CPUSET=0
SPRING_CPUSET=1
POSTGRES_CPUSET=2
SPRING_WEBFLUX_CPUSET=3
GO_CPUSET=0

ASPNET_CPUS=1.0
SPRING_CPUS=1.0
POSTGRES_CPUS=1.0
SPRING_WEBFLUX_CPUS=1.0
GO_CPUS=1.0

ASPNET_MEM_LIMIT=1g
SPRING_MEM_LIMIT=1g
POSTGRES_MEM_LIMIT=1g
SPRING_WEBFLUX_MEM_LIMIT=1g
GO_MEM_LIMIT=1g

ASPNET_MEM_RESERVATION=768m
SPRING_MEM_RESERVATION=768m
POSTGRES_MEM_RESERVATION=768m
SPRING_WEBFLUX_MEM_RESERVATION=768m
GO_MEM_RESERVATION=256m

ASPNET_PIDS_LIMIT=256
SPRING_PIDS_LIMIT=256
POSTGRES_PIDS_LIMIT=256
SPRING_WEBFLUX_PIDS_LIMIT=256
GO_PIDS_LIMIT=256

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
YIELD_INTERVAL_MS=100
THREAD_POOL_MAX=1